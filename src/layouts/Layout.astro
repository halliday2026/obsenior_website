---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/'); // normalize: always ends with /

const {
  title = 'OB Senior Concierge | Non-Medical Senior Support San Diego',
  description = 'Personalized, non-medical senior concierge services in Carmel Valley, Rancho Bernardo, and North County San Diego. Administrative support, scheduling, errands, and more.',
  ogImage = `${Astro.site}${base.replace(/^\//, '')}og-image.jpg`,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'OB Senior Concierge',
  description: 'Non-medical senior concierge and support services in North County San Diego.',
  telephone: '858-722-1930',
  email: 'obpmservices@gmail.com',
  url: 'https://halliday2026.github.io/obsenior_website',
  areaServed: [
    { '@type': 'City', name: 'Carmel Valley' },
    { '@type': 'City', name: 'Rancho Bernardo' },
    { '@type': 'City', name: 'San Diego' },
  ],
  serviceType: 'Non-medical senior support and concierge services',
  priceRange: '$$',
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#1f3a52" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <!-- TODO: Replace with actual 1200×630 OG image before launch -->
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="OB Senior Concierge" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Fonts: Cormorant Garamond (serif headings) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400;1,600&family=Inter:wght@400;500;600&display=swap"
    />

    <!-- Favicon (SVG monogram — works in all modern browsers) -->
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />
  </body>
</html>

---
interface Props {
  size?: number;
  class?: string;
}
const { size = 44, class: className } = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 44 44"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  class={className}
>
  <!-- Outer circle ring in gold -->
  <circle cx="22" cy="22" r="20.5" stroke="#b08d4f" stroke-width="1.25" fill="#1f3a52" />
  <!-- OB letterform in cream -->
  <text
    x="22"
    y="30"
    text-anchor="middle"
    font-family="Cormorant Garamond, Georgia, serif"
    font-size="18"
    font-weight="600"
    letter-spacing="1"
    fill="#f7f3ec"
  >OB</text>
</svg>

---
import OBMonogram from './OBMonogram.astro';
const base = import.meta.env.BASE_URL;
---
<header class="site-nav" role="banner">
  <nav class="nav-inner container" aria-label="Main navigation">
    <a href={`${base}#hero`} class="nav-brand" aria-label="OB Senior Concierge — home">
      <OBMonogram size={40} />
      <div class="nav-wordmark">
        <span class="wordmark-name">OB Senior Concierge</span>
        <span class="wordmark-tag">Professional Support for Independent Living</span>
      </div>
    </a>

    <button
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="nav-menu"
      aria-label="Open navigation menu"
      type="button"
    >
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <rect class="bar bar-top" x="2" y="5" width="18" height="2" rx="1" fill="currentColor"/>
        <rect class="bar bar-mid" x="2" y="10" width="18" height="2" rx="1" fill="currentColor"/>
        <rect class="bar bar-bot" x="2" y="15" width="18" height="2" rx="1" fill="currentColor"/>
      </svg>
    </button>

    <ul id="nav-menu" class="nav-links" role="list">
      <li><a href={`${base}#services`}>Services</a></li>
      <li><a href={`${base}#how-it-works`}>How It Works</a></li>
      <li><a href={`${base}#pricing`}>Pricing</a></li>
      <li><a href={`${base}#about`}>About</a></li>
      <li><a href={`${base}#contact`}>Contact</a></li>
      <li>
        <a href="tel:8587221930" class="btn btn-primary nav-cta" aria-label="Call us at 858-722-1930">
          858-722-1930
        </a>
      </li>
    </ul>
  </nav>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--nav-height);
    background: rgb(255 255 255 / 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgb(31 58 82 / 0.1);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    gap: 1rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: var(--ink);
    flex-shrink: 0;
  }

  .nav-wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .wordmark-name {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--ink);
  }

  .wordmark-tag {
    font-size: 0.6rem;
    color: var(--muted);
    letter-spacing: 0.04em;
    font-weight: 400;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    display: block;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    border-radius: var(--radius);
    transition: background var(--transition), color var(--transition);
    white-space: nowrap;
  }

  .nav-links a:hover {
    background: rgb(31 58 82 / 0.06);
    color: var(--ink);
  }

  .nav-links a[aria-current="page"] {
    color: var(--accent);
  }

  .nav-cta {
    margin-left: 0.5rem;
    font-size: 0.85rem !important;
    padding: 0.5rem 1.25rem !important;
    min-height: 40px !important;
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--ink);
    padding: 0.5rem;
    border-radius: var(--radius);
    transition: background var(--transition);
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
  }

  .nav-toggle:hover { background: rgb(31 58 82 / 0.06); }

  @media (max-width: 820px) {
    .wordmark-tag { display: none; }
  }

  @media (max-width: 720px) {
    .nav-toggle {
      display: flex;
    }

    .nav-links {
      display: none;
      position: fixed;
      inset: var(--nav-height) 0 0 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--surface);
      padding: 1rem;
      border-top: 1px solid rgb(31 58 82 / 0.1);
      overflow-y: auto;
      z-index: 99;
    }

    .nav-links.is-open {
      display: flex;
    }

    .nav-links li { width: 100%; }

    .nav-links a {
      font-size: 1.1rem;
      padding: 0.85rem 1rem;
    }

    .nav-cta {
      margin-left: 0 !important;
      margin-top: 0.5rem;
      text-align: center;
      justify-content: center;
      font-size: 1rem !important;
      padding: 0.85rem 1.25rem !important;
      min-height: 48px !important;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement | null;
  const menu = document.querySelector('#nav-menu') as HTMLElement | null;

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('is-open');
      if (!expanded) {
        (menu.querySelector('a') as HTMLElement | null)?.focus();
      }
    });

    menu.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        menu.classList.remove('is-open');
      });
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.classList.contains('is-open')) {
        toggle.setAttribute('aria-expanded', 'false');
        menu.classList.remove('is-open');
        toggle.focus();
      }
    });

    // Active section highlighting
    const sections = document.querySelectorAll<HTMLElement>('section[id]');
    const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-links a[href*="#"]');

    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          navLinks.forEach(a => {
            a.removeAttribute('aria-current');
            if (a.getAttribute('href')?.endsWith('#' + entry.target.id)) {
              a.setAttribute('aria-current', 'page');
            }
          });
        }
      });
    }, { rootMargin: '-40% 0px -55% 0px' });

    sections.forEach(s => observer.observe(s));
  }
</script>

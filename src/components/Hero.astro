---
---
<section id="hero" class="hero" aria-labelledby="hero-heading">
  <div class="container hero-inner">
    <div class="hero-text reveal">
      <p class="section-label">Serving North County San Diego</p>
      <h1 id="hero-heading">
        Calm, capable support — so you can live life on your own terms.
      </h1>
      <p class="hero-sub">
        Non-medical concierge services for seniors and the families who love them.
        Personalized, discreet, and always personally delivered.
      </p>
      <div class="hero-ctas">
        <a href="#contact" class="btn btn-primary">Request a Consultation</a>
        <a href="tel:8587221930" class="btn btn-outline">Call 858-722-1930</a>
      </div>
      <p class="hero-trust">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="7.5" stroke="#8aa090" stroke-width="1"/>
          <path d="M4.5 8l2.5 2.5 4.5-4.5" stroke="#8aa090" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Carmel Valley · Rancho Bernardo · North County San Diego
      </p>
    </div>

    <div class="hero-visual reveal" >
      <!--
        Stock photo: smiling senior woman — via Unsplash (free to use).
        TODO: Replace with Donna's preferred real photography when available.
        Swap in public/hero-photo.jpg with your own image (keep the same filename).
      -->
      <img
        src={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}hero-photo.jpg`}
        alt="A cheerful senior woman enjoying a bright, calm moment at home"
        width="900"
        height="675"
        loading="eager"
        fetchpriority="high"
        class="hero-photo"
      />
    </div>
  </div>

  <!-- Decorative wave divider -->
  <div class="hero-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 48" fill="none" preserveAspectRatio="none">
      <path d="M0 48 C360 0 1080 0 1440 48 L1440 48 L0 48 Z" fill="white"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    background: var(--cream);
    position: relative;
    padding-block: clamp(4rem, 10vw, 7rem) clamp(5rem, 11vw, 8rem);
    overflow: hidden;
  }

  /* Subtle radial glow in top-left for warmth */
  .hero::before {
    content: '';
    position: absolute;
    top: -10%;
    left: -5%;
    width: 50%;
    height: 80%;
    background: radial-gradient(ellipse, rgb(176 141 79 / 0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-text { max-width: 560px; }

  h1 {
    margin-bottom: 1.25rem;
    color: var(--ink);
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--muted);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--muted);
    max-width: none;
  }

  /* Hero photo */
  .hero-visual {
    position: relative;
  }

  .hero-photo {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .hero-wave {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 48px;
  }

  .hero-wave svg {
    width: 100%;
    height: 100%;
  }

  @media (max-width: 820px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      order: -1;
      max-width: 480px;
      margin-inline: auto;
      width: 100%;
    }

    .hero-placeholder { min-height: 240px; }
  }

  @media (max-width: 480px) {
    .hero-ctas { flex-direction: column; }
    .hero-ctas .btn { justify-content: center; }
  }
</style>

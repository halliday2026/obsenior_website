---
const services = [
  {
    title: 'Administrative & Technology Support',
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="6" y="8" width="28" height="20" rx="2"/><line x1="14" y1="32" x2="26" y2="32"/><line x1="20" y1="28" x2="20" y2="32"/><line x1="11" y1="14" x2="29" y2="14"/><line x1="11" y1="19" x2="22" y2="19"/></svg>`,
    bullets: [
      'Organizing paperwork, bills & mail',
      'Help with online accounts & email',
      'Everyday technology assistance',
    ],
  },
  {
    title: 'Scheduling & Coordination',
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="6" y="8" width="28" height="26" rx="2"/><line x1="14" y1="4" x2="14" y2="12"/><line x1="26" y1="4" x2="26" y2="12"/><line x1="6" y1="18" x2="34" y2="18"/><rect x="12" y="23" width="5" height="5" rx="1"/><rect x="23" y="23" width="5" height="5" rx="1"/></svg>`,
    bullets: [
      'Appointment scheduling & reminders',
      'Service coordination & planning',
      'Calendar management & follow-up',
    ],
  },
  {
    title: 'Personal Organization',
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 8h20l2 4H8l2-4z"/><rect x="8" y="12" width="24" height="22" rx="2"/><line x1="14" y1="20" x2="26" y2="20"/><line x1="14" y1="26" x2="20" y2="26"/></svg>`,
    bullets: [
      'Light organization of home & workspace',
      'Sorting files, belongings & storage',
      'Creating orderly, peaceful spaces',
    ],
  },
  {
    title: 'Concierge Assistance',
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="20" cy="14" r="6"/><path d="M8 34c0-6.627 5.373-12 12-12s12 5.373 12 12"/><path d="M20 26v6"/><line x1="16" y1="32" x2="24" y2="32"/></svg>`,
    bullets: [
      'Errands and local tasks',
      'Friendly social visits',
      'Meal prep & healthy-lifestyle reminders',
      'Flexible support tailored to your needs',
    ],
  },
  {
    title: 'Transportation & Local Support',
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="14" width="32" height="18" rx="3"/><circle cx="12" cy="32" r="3"/><circle cx="28" cy="32" r="3"/><path d="M4 22h32"/><path d="M14 14V8a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v6"/></svg>`,
    bullets: [
      'Rides to appointments & errands',
      'Accompaniment as needed',
      'Help navigating community resources',
    ],
  },
];
---
<section id="services" class="services" aria-labelledby="services-heading">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-label">What We Offer</p>
      <h2 id="services-heading">Support That Fits Your Life</h2>
      <div class="divider"></div>
      <p class="section-intro">
        Every service is delivered personally — not by a rotating roster of helpers,
        but by one familiar, trusted presence.
      </p>
    </div>

    <ul class="services-grid" role="list">
      {services.map(s => (
        <li class="service-card reveal">
          <div class="service-icon">
            <Fragment set:html={s.icon} />
          </div>
          <h3>{s.title}</h3>
          <ul class="service-bullets" role="list">
            {s.bullets.map(b => <li>{b}</li>)}
          </ul>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .services {
    background: var(--surface);
  }

  .section-header {
    margin-bottom: 3rem;
  }

  .services-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* 3 cards per row on desktop → last row of 2 is centered automatically */
  .service-card {
    flex: 0 1 calc(33.333% - 1rem);
    min-width: 240px;
    background: var(--cream);
    border-radius: var(--radius-lg);
    padding: 2rem 1.75rem;
    border-top: 3px solid var(--accent);
    transition: transform var(--transition), box-shadow var(--transition);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (prefers-reduced-motion: no-preference) {
    .service-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-md);
    }
  }

  .service-icon {
    color: var(--sage);
    display: flex;
    width: 40px;
    height: 40px;
  }

  .service-card h3 {
    font-size: 1.1rem;
    color: var(--ink);
    line-height: 1.3;
  }

  .service-bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .service-bullets li {
    font-size: 0.9rem;
    color: var(--muted);
    padding-left: 1.1rem;
    position: relative;
    line-height: 1.5;
  }

  .service-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.7;
  }
</style>

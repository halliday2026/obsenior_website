---
const steps = [
  {
    number: '1',
    title: 'A Friendly Conversation',
    description:
      'We begin with a no-pressure call or meeting to hear about your situation, your daily routines, and what kind of support would feel most helpful.',
  },
  {
    number: '2',
    title: 'A Tailored Support Plan',
    description:
      'Together we design a plan that fits naturally into your life — flexible hours, specific tasks, and a schedule that works for you.',
  },
  {
    number: '3',
    title: 'Steady, Reliable Help — Personally Delivered',
    description:
      'You get consistent, one-on-one support from the same person every visit. No surprises, no strangers — just dependable help you can count on.',
  },
];
---
<section id="how-it-works" class="how-it-works" aria-labelledby="hiw-heading">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-label">Getting Started</p>
      <h2 id="hiw-heading">How It Works</h2>
      <div class="divider"></div>
      <p class="section-intro">
        Simple, unhurried, and always on your terms. Every new relationship begins
        with a complimentary consultation.
      </p>
    </div>

    <ol class="steps" role="list">
      {steps.map((step, i) => (
        <li class="step reveal">
          <div class="step-number" aria-hidden="true">{step.number}</div>
          <div class="step-connector" aria-hidden="true"></div>
          <div class="step-content">
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        </li>
      ))}
    </ol>

    <div class="hiw-note reveal">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <circle cx="9" cy="9" r="8" stroke="#8aa090" stroke-width="1.25"/>
        <path d="M9 5v4l2.5 2.5" stroke="#8aa090" stroke-width="1.25" stroke-linecap="round"/>
      </svg>
      <p>Every plan begins with a complimentary consultation — no commitment required.</p>
    </div>
  </div>
</section>

<style>
  .how-it-works {
    background: var(--cream);
  }

  .section-header { margin-bottom: 3rem; }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    list-style: none;
    margin: 0 0 2.5rem;
    padding: 0;
    position: relative;
  }

  /* Horizontal connector line between steps on desktop */
  .steps::before {
    content: '';
    position: absolute;
    top: 2rem; /* aligns with step-number center */
    left: calc(100% / 6);
    width: calc(100% * 2 / 3);
    height: 1px;
    border-top: 2px dashed rgb(138 160 144 / 0.4);
    z-index: 0;
  }

  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  .step-number {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background: var(--ink);
    color: var(--cream);
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    flex-shrink: 0;
    position: relative;
    z-index: 2;
    box-shadow: 0 0 0 4px var(--cream), 0 0 0 6px rgb(31 58 82 / 0.15);
  }

  .step-connector { display: none; }

  .step-content h3 {
    margin-bottom: 0.6rem;
    color: var(--ink);
    font-size: 1.1rem;
  }

  .step-content p {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.65;
    max-width: 22ch;
    margin-inline: auto;
  }

  .hiw-note {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    background: rgb(138 160 144 / 0.1);
    border: 1px solid rgb(138 160 144 / 0.25);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    max-width: 520px;
  }

  .hiw-note svg { flex-shrink: 0; margin-top: 0.15rem; }

  .hiw-note p {
    font-size: 0.9rem;
    color: var(--muted);
    max-width: none;
  }

  @media (max-width: 700px) {
    .steps {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .steps::before { display: none; }

    .step { flex-direction: row; text-align: left; gap: 1.25rem; }
    .step-number { margin-bottom: 0; }
    .step-content p { margin-inline: 0; max-width: none; }
  }
</style>

---
const moments = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    text: 'Staying independent at home, with the right support in place',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
    text: 'Keeping up with appointments, paperwork, and day-to-day administration',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    text: 'Having one reliable, familiar person to call — not a rotation of strangers',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
    text: 'Helping adult children support aging parents with confidence and peace of mind',
  },
];
---
<section class="reassurance" aria-labelledby="reassurance-heading">
  <div class="container">
    <div class="reassurance-header">
      <div class="divider-gold" aria-hidden="true"></div>
      <h2 id="reassurance-heading">
        When life gets a little complicated&hellip;
      </h2>
      <p class="reassurance-lead">
        We understand that asking for help is a meaningful step. Whether you're
        navigating change on your own or supporting a parent from afar, OB Senior
        Concierge offers steady, discreet support — exactly when it's needed.
      </p>
    </div>

    <ul class="moments-grid" role="list">
      {moments.map(m => (
        <li class="moment reveal">
          <div class="moment-icon" set:html={m.icon} />
          <p>{m.text}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .reassurance {
    background: var(--ink);
    color: var(--cream);
    padding-block: clamp(4rem, 9vw, 6rem);
  }

  .reassurance-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .divider-gold {
    width: 3rem;
    height: 2px;
    background: var(--accent);
    margin-inline: auto;
    margin-bottom: 1.5rem;
  }

  .reassurance h2 {
    color: var(--cream);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 1rem;
  }

  .reassurance-lead {
    color: rgb(247 243 236 / 0.75);
    font-size: 1.05rem;
    max-width: 56ch;
    margin-inline: auto;
    line-height: 1.7;
  }

  .moments-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .moment {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.75rem;
    background: rgb(255 255 255 / 0.05);
    border-radius: var(--radius);
    border: 1px solid rgb(255 255 255 / 0.08);
  }

  .moment-icon {
    color: var(--sage);
    display: flex;
  }

  .moment p {
    color: rgb(247 243 236 / 0.85);
    font-size: 0.95rem;
    line-height: 1.6;
    max-width: none;
  }
</style>
